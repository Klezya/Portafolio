---
interface Props {
  title: string;
  subtitle: string;
  description: string;
  features: string[];
  tags: string[];
  link: string;
  linkLabel: string;
  image: string;
  imageAlt: string;
  placeholderEmoji: string;
  i18nPrefix: string;
  repoLink?: string;
  wip?: boolean;
}

const { title, subtitle, description, features, tags, link, linkLabel, image, imageAlt, placeholderEmoji, i18nPrefix, repoLink, wip } = Astro.props;
---

<article class="card flex flex-col gap-0 overflow-hidden card-soft-bg" style="padding: 0;">
  <div class="relative w-full h-52 overflow-hidden" style="background-color: var(--color-bg-muted);">
    <img
      src={image}
      alt={imageAlt}
      class="w-full h-full object-cover project-image"
      width="600"
      height="208"
      loading="lazy"
    />
    <div
      class="absolute inset-0 items-center justify-center flex-col gap-2 project-placeholder hidden"
      style="background-color: var(--color-bg-muted);"
    >
      <span style="font-size: 2.5rem;">{placeholderEmoji}</span>
      <span class="text-xs" style="color: var(--color-text-subtle);">{image.split('/').pop()}</span>
    </div>
    {wip && (
      <div class="absolute top-3 right-3 flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold tracking-wide wip-badge">
        <span class="wip-dot"></span>
        WIP
      </div>
    )}
  </div>

  <div class="flex flex-col gap-5 flex-1" style="padding: 1.5rem;">
    <div>
      <h3 class="text-xl font-bold mb-1" style="color: var(--color-text);">{title}</h3>
      <p class="text-xs font-medium tracking-wide uppercase" style="color: var(--color-accent);" data-i18n={`${i18nPrefix}.subtitle`}>{subtitle}</p>
    </div>

    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="badge">{tag}</span>
      ))}
    </div>

    <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);" data-i18n={`${i18nPrefix}.description`}>
      {description}
    </p>

    <ul class="flex flex-col gap-2">
      {features.map((feat, index) => (
        <li class="flex items-start gap-2 text-sm" style="color: var(--color-text-muted);">
          <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: var(--color-accent);"></span>
          <span data-i18n={`${i18nPrefix}.feature${index + 1}`}>{feat}</span>
        </li>
      ))}
    </ul>

    <div class="flex flex-wrap items-center gap-3 mt-auto">
      <a href={link} target="_blank" rel="noopener" class="btn-secondary text-sm" data-i18n="projects.view">Ver proyecto →</a>
      {repoLink ? (
        <a
          href={repoLink}
          target="_blank"
          rel="noopener"
          class="btn-repo text-sm flex items-center gap-1.5"
          data-i18n="projects.repo"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
            <path d="M9 18c-4.51 2-5-2-7-2"/>
          </svg>
          Ver repositorio
        </a>
      ) : (
        <span
          class="btn-repo-disabled text-sm flex items-center gap-1.5"
          title="Repositorio privado"
          data-i18n="projects.repo.private"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Repositorio privado
        </span>
      )}
    </div>
  </div>
</article>

<style>
  .project-details summary::-webkit-details-marker {
    display: none;
  }
  .project-details summary::marker {
    display: none;
    content: '';
  }
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.2s ease-out;
  }

  .btn-repo {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.4rem 0.85rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-repo:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .btn-repo-disabled {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.4rem 0.85rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-subtle);
    opacity: 0.55;
    cursor: not-allowed;
    user-select: none;
  }

  .wip-badge {
    background-color: color-mix(in srgb, var(--color-accent) 15%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
    color: var(--color-accent);
    backdrop-filter: blur(4px);
  }

  .wip-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-accent);
    animation: pulse-dot 1.8s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.75); }
  }
</style>
