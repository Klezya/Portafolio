---
const techStack = ['Python', 'Docker', 'AWS', 'REST APIs', 'Ciberseguridad'];
---

<section class="section-separated container flex flex-col lg:flex-row items-center justify-between min-h-[88dvh] py-32 gap-20 max-w-6xl">
  <div class="flex flex-col gap-8 flex-1">
    <div class="hero-stagger flex items-center gap-3" style="--stagger: 0;">
      <span class="availability-pin">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        <span data-i18n="hero.available">Disponible para trabajar</span>
      </span>
    </div>

    <div class="hero-stagger flex items-center gap-3" style="--stagger: 1;">
      <span class="inline-block w-8 h-px" style="background-color: var(--color-accent);" aria-hidden="true"></span>
      <span class="text-sm font-medium tracking-widest uppercase" style="color: var(--color-accent);" data-i18n="hero.role">
        Ingeniero en Computación & Informática
      </span>
    </div>

    <div class="hero-stagger flex flex-col gap-2" style="--stagger: 2;">
      <p class="text-lg font-medium" style="color: var(--color-text-muted);" data-i18n="hero.greeting">Hola, soy</p>
      <h1 class="text-6xl sm:text-7xl md:text-8xl font-bold leading-none tracking-tight" style="color: var(--color-text); text-wrap: balance;">
        Benjamín<br />
        <span style="color: var(--color-accent);">Núñez.</span>
      </h1>
    </div>

    <p class="hero-stagger text-xl sm:text-2xl leading-relaxed max-w-2xl" style="color: var(--color-text-muted); --stagger: 3;" data-i18n-html="hero.bio">
      Developer enfocado en sistemas backend con <strong style="color: var(--color-text); font-weight: 600;">Python</strong>,
      <strong style="color: var(--color-text); font-weight: 600;">Docker</strong> y
      <strong style="color: var(--color-text); font-weight: 600;">AWS</strong> —
      actualmente aprendiendo <strong style="color: var(--color-text); font-weight: 600;">Ciberseguridad</strong>,
      <strong style="color: var(--color-text); font-weight: 600;">Escalabilidad Cloud</strong> y
      <strong style="color: var(--color-text); font-weight: 600;">DevOps</strong>.
    </p>

    <p class="hero-stagger text-sm" style="color: var(--color-text-subtle); --stagger: 4;" data-i18n="hero.education">
      Egresado · Universidad Andrés Bello
    </p>

    <div class="hero-stagger flex flex-wrap gap-2" style="--stagger: 5;">
      {techStack.map((tech) => (
        <span class="badge">{tech}</span>
      ))}
    </div>

    <div class="hero-stagger flex flex-wrap gap-4" style="--stagger: 6;">
      <a href="#proyectos" class="btn-primary" data-i18n="hero.cta.projects">Ver proyectos</a>
      <a href="#contacto" class="btn-secondary" data-i18n="hero.cta.contact">Contacto</a>
      <a href="/cv.pdf" target="_blank" rel="noopener" class="btn-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <line x1="10" y1="9" x2="8" y2="9"/>
        </svg>
        <span data-i18n="hero.cta.cv">Ver CV</span>
      </a>
    </div>
  </div>

  <div class="hero-stagger flex-shrink-0 flex flex-col items-center gap-4" style="--stagger: 7;">
    <div
      class="relative w-64 h-64 sm:w-80 sm:h-80 rounded-2xl overflow-hidden"
      style="border: 2px solid var(--color-border); box-shadow: var(--shadow-lg);"
    >
      <img
        src="/profile.jpg"
        alt="Fotografía de Benjamín Núñez"
        class="w-full h-full object-cover"
        id="hero-photo"
        width="320"
        height="320"
        fetchpriority="high"
        data-i18n-alt="hero.photo.alt"
      />
      <div
        id="hero-placeholder"
        class="absolute inset-0 flex flex-col items-center justify-center gap-3 hidden"
        style="background-color: var(--color-bg-muted);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-text-subtle);">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
        <span class="text-xs font-medium" style="color: var(--color-text-subtle);">Tu fotografía aquí</span>
      </div>
    </div>

    <!-- Social links below photo -->
    <div class="flex items-center gap-3">
      <a
        href="https://github.com/Klezya"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="flex items-center justify-center w-10 h-10 rounded-lg transition-colors duration-200"
        style="color: var(--color-text-muted); border: 1px solid var(--color-border); background-color: var(--color-bg-muted);"
        onmouseover="this.style.color='var(--color-text)'; this.style.borderColor='var(--color-accent)';"
        onmouseout="this.style.color='var(--color-text-muted)'; this.style.borderColor='var(--color-border)';"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/benjamin-nunez-klezya/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="flex items-center justify-center w-10 h-10 rounded-lg transition-colors duration-200"
        style="color: var(--color-text-muted); border: 1px solid var(--color-border); background-color: var(--color-bg-muted);"
        onmouseover="this.style.color='var(--color-text)'; this.style.borderColor='var(--color-accent)';"
        onmouseout="this.style.color='var(--color-text-muted)'; this.style.borderColor='var(--color-border)';"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </div>
  </div>
</section>
